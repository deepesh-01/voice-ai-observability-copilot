# HighLevel Marketplace App — copy to `.env` and fill in. NEVER commit the real .env.
# Obtain CLIENT_ID / CLIENT_SECRET from: Marketplace Dev Portal → your app → Manage → Secrets.
CLIENT_ID=your-ghl-app-client-id
CLIENT_SECRET=your-ghl-app-client-secret

# Public base URL (the cloudflared permanent URL). Used to build the OAuth redirect URI.
PUBLIC_BASE_URL=https://voai.deepesh-engg.in

# Port the backend listens on locally (cloudflared ingress maps the hostname here).
PORT=8095

# Scopes — MUST be a subset of what's enabled+saved on the app (A-007).
# voice-ai-dashboard.readonly = call logs + transcripts (core). agents/goals = cross-agent + KPIs.
# voice-ai-agents.write = required for the dashboard's "Apply" action to PATCH an agent prompt (S-012).
SCOPES=voice-ai-dashboard.readonly voice-ai-agents.readonly voice-ai-agents.write voice-ai-agent-goals.readonly conversations.readonly conversations/message.readonly conversation-ai.readonly

# Anthropic (used later for KPI scoring / recommendations — ADR-0002).
ANTHROPIC_API_KEY=

# Bearer token guarding the read API (/api/*). Generate with: openssl rand -hex 32
# When set, /api requires `Authorization: Bearer <token>`; the server injects it into
# the served SPA so the dashboard still works. Leave empty in local dev (API open).
API_AUTH_TOKEN=
