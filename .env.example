# HighLevel Marketplace App — copy to `.env` and fill in. NEVER commit the real .env.
# Obtain CLIENT_ID / CLIENT_SECRET from: Marketplace Dev Portal → your app → Manage → Secrets.
CLIENT_ID=your-ghl-app-client-id
CLIENT_SECRET=your-ghl-app-client-secret

# Public base URL (the cloudflared permanent URL). Used to build the OAuth redirect URI.
PUBLIC_BASE_URL=https://voai.deepesh-engg.in

# Port the backend listens on locally (cloudflared ingress maps the hostname here).
PORT=8095

# Anthropic (used later for KPI scoring / recommendations — ADR-0002).
ANTHROPIC_API_KEY=
